# ============================================================================
# PRODUCTION .ENV TEMPLATE — TeleTime QuotationApp
# Generated: 2026-03-17
# ============================================================================
# Copy to /opt/teletime/backend/.env on the EC2 instance.
# Fill in ALL required values (marked REQUIRED). Optional values have defaults.
# NEVER commit actual secrets — use AWS Secrets Manager or similar.
# ============================================================================


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  DATABASE (PostgreSQL on AWS RDS)                                        ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

DB_HOST=                              # REQUIRED — RDS endpoint (e.g., mydb.ccrqkqs0m6eu.us-east-1.rds.amazonaws.com)
DB_PORT=5432
DB_NAME=                              # REQUIRED — database name
DB_USER=                              # REQUIRED — app_user (subject to RLS)
DB_PASSWORD=                          # REQUIRED — app_user password
DB_ADMIN_USER=                        # REQUIRED — dbadmin (bypasses RLS, used for migrations/jobs)
DB_ADMIN_PASSWORD=                    # REQUIRED — dbadmin password
DB_SSL=true
DB_SSL_MODE=require
DB_SSL_REJECT_UNAUTHORIZED=true       # Must be true in production

# Connection pool tuning (optional — sensible defaults)
# DB_POOL_MAX=20
# DB_POOL_MIN=2
# DB_IDLE_TIMEOUT=30000
# DB_CONNECT_TIMEOUT=5000
# DB_ACQUIRE_TIMEOUT=30000
# DB_STATEMENT_TIMEOUT=30000
# DB_DEBUG=false


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SERVER                                                                  ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

PORT=3001
NODE_ENV=production
LOG_LEVEL=info
TIMEZONE=America/Toronto

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=                      # REQUIRED — e.g., https://app.teletime.ca,https://pos.teletime.ca


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  AUTHENTICATION & SECURITY                                               ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Generate each: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=                           # REQUIRED — 128-char hex string
JWT_REFRESH_SECRET=                   # REQUIRED — 128-char hex string (different from JWT_SECRET)
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Fraud detection — hashing salt for card identifiers
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Changing this resets all velocity tracking history
FRAUD_SALT=                           # REQUIRED — 64-char hex string


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  AWS SERVICES                                                            ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

AWS_ACCESS_KEY_ID=                    # REQUIRED — IAM user with SES + S3 permissions
AWS_SECRET_ACCESS_KEY=                # REQUIRED
AWS_REGION=us-east-1

# S3 (file storage: voice notes, invoice PDFs, product images)
S3_BUCKET=                            # S3 bucket name
CDN_BASE_URL=                         # e.g., https://your-bucket.s3.amazonaws.com


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  EMAIL (AWS SES)                                                         ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

EMAIL_FROM=                           # REQUIRED — verified SES sender (e.g., dave@teletime.ca)
EMAIL_FROM_NAME=TeleTime
SES_FROM_EMAIL=                       # Optional — falls back to EMAIL_FROM
SES_FROM_NAME=TeleTime POS
ADMIN_EMAIL=                          # System notification recipient
SALES_TEAM_EMAIL=                     # Sales team notifications (falls back to EMAIL_FROM)
SALES_NOTIFICATION_EMAIL=             # Optional — additional sales notifications


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  COMPANY BRANDING (PDFs, invoices, receipts)                             ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

COMPANY_NAME=
COMPANY_ADDRESS=
COMPANY_CITY=
COMPANY_PHONE=
COMPANY_EMAIL=
COMPANY_WEBSITE=
COMPANY_LANDMARK=
STORE_PHONE=


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  BANKING & INSTITUTIONAL INVOICING                                       ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

TELETIME_BANK_NAME=
TELETIME_BANK_TRANSIT=
TELETIME_BANK_ACCOUNT=
TELETIME_REMITTANCE_ADDRESS=
TELETIME_HST_NUMBER=
TAX_NUMBER=


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  MONERIS PAYMENT GATEWAY (Primary)                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

MONERIS_STORE_ID=                     # REQUIRED for payments — from Moneris portal
MONERIS_API_TOKEN=                    # REQUIRED for payments
MONERIS_CHECKOUT_ID=
MONERIS_ENVIRONMENT=production        # testing | production
MONERIS_BILLING_DESCRIPTOR=TeleTime

# Webhook HMAC secret — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MONERIS_WEBHOOK_SECRET=


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  STRIPE PAYMENT GATEWAY (Secondary)                                     ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

STRIPE_SECRET_KEY=                    # Optional — sk_live_...
STRIPE_PUBLISHABLE_KEY=               # Optional — pk_live_...
STRIPE_WEBHOOK_SECRET=                # Optional — whsec_...
STRIPE_MODE=live                      # test | live


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  E-TRANSFER                                                              ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

ETRANSFER_EMAIL=                      # e.g., payments@teletime.ca


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  FINANCING PROVIDERS (all optional)                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

