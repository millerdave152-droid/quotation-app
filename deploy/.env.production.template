APPROVAL_DISCOUNT_THRESHOLD=15        # % discount requiring approval
APPROVAL_AMOUNT_THRESHOLD=1000000     # Amount in cents ($10,000) requiring approval
APPROVAL_MARGIN_THRESHOLD=20          # Basis points margin threshold


