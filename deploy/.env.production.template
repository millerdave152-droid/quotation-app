AFFIRM_PUBLIC_KEY=
AFFIRM_PRIVATE_KEY=
AFFIRM_API_URL=                       # Production: https://api.affirm.com

KLARNA_ENABLED=false
KLARNA_USERNAME=
KLARNA_PASSWORD=
KLARNA_API_URL=                       # Production: https://api.klarna.com

SYNCHRONY_ENABLED=false
SYNCHRONY_MERCHANT_ID=
SYNCHRONY_API_URL=


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  MARKETPLACE (Mirakl / Best Buy Canada)                                  ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

