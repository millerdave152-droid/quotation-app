# ML_SCORING_URL=
# ML_MODEL_VERSION=placeholder-v0
# ML_WEIGHT=0.4
# RULE_WEIGHT=0.6


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  CACHING (Redis optional — falls back to PostgreSQL/in-memory)           ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

REDIS_URL=                            # e.g., redis://localhost:6379 or rediss://user:pass@host:6380
