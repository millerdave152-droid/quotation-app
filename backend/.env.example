# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# For TeleTime Quotation App with POS & Marketplace Integration
# Copy this file to .env and fill in your values
# ============================================================================
# IMPORTANT: Never commit .env to version control. Only .env.example is safe.
# See SECRETS_ROTATION_CHECKLIST.md for rotation procedures.
# ============================================================================

# Database Configuration
# AWS RDS instance — get credentials from AWS Secrets Manager or your DBA
DB_HOST=your-database-host.rds.amazonaws.com
DB_NAME=quotationapp
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_ADMIN_USER=your_admin_user
DB_ADMIN_PASSWORD=your_admin_password
DB_PORT=5432
DB_SSL=true
DB_SSL_MODE=require
# SECURITY: Must be true in production to prevent man-in-the-middle attacks.
# The db.js config enforces rejectUnauthorized=true when NODE_ENV=production
# regardless of this value. Set to false only for local dev with self-signed certs.
DB_SSL_REJECT_UNAUTHORIZED=true

# Database Connection Pool (optional — sensible defaults shown)
# DB_POOL_MAX=20
# DB_POOL_MIN=2
# DB_IDLE_TIMEOUT=30000
# DB_CONNECT_TIMEOUT=5000
# DB_ACQUIRE_TIMEOUT=30000
# DB_STATEMENT_TIMEOUT=30000
# DB_DEBUG=false

# AI / LLM
# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# OpenAI (optional — used for embeddings/vector search)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# AWS SES Credentials (for email sending)
# Create IAM user with SES permissions: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# S3 (for voice notes, invoice PDFs, product images)
S3_BUCKET=your-s3-bucket
CDN_BASE_URL=https://your-bucket.s3.amazonaws.com

# Email Configuration
EMAIL_FROM=your-email@example.com
# Display name for outgoing emails (optional, defaults to 'Your Company')
# EMAIL_FROM_NAME=TeleTime
# Admin email for system notifications (optional)
# ADMIN_EMAIL=admin@example.com

# Server Configuration
PORT=3001
NODE_ENV=development

# Production CORS — comma-separated origins (used when NODE_ENV=production)
ALLOWED_ORIGINS=https://app.example.com,https://pos.example.com

# JWT Authentication (REQUIRED)
# Generate each with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-a-secure-random-string-here
JWT_REFRESH_SECRET=generate-another-secure-random-string
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# ============================================================================
# BATCH EMAIL PROCESSING (optional — sensible defaults shown)
# ============================================================================
# BATCH_EMAIL_MAX_SIZE=50
# BATCH_EMAIL_DELAY_MS=1000
# BATCH_EMAIL_MAX_RETRIES=3

# ============================================================================
# EXCEL AUTOMATION INTEGRATION SETTINGS
# ============================================================================

# Path to cleaned CSV files from Excel automation
CLEANED_DATA_PATH=C:\\path\\to\\cleaned_data

# Path to price reports from Excel automation
PRICE_REPORTS_PATH=C:\\path\\to\\price_reports

# Auto-import settings
AUTO_IMPORT_ENABLED=true
SYNC_INTERVAL_MINUTES=15

# Notification settings (Optional)
NOTIFICATION_ENABLED=false
NOTIFICATION_EMAIL=your-email@example.com

# Logging (Optional)
LOG_LEVEL=info

# ============================================================================
# PWA PUSH NOTIFICATIONS
# ============================================================================
# Generate VAPID keys using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your-email@example.com

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
# Cache TTL values in seconds (optional - defaults shown)
CACHE_TTL_SHORT=300       # 5 minutes - for frequently changing data
CACHE_TTL_MEDIUM=1800     # 30 minutes - for moderately stable data
CACHE_TTL_LONG=7200       # 2 hours - for rarely changing data
CACHE_MAX_ENTRIES=1000    # Maximum entries before LRU eviction
CACHE_ENABLED=true        # Set to 'false' to disable caching

# ============================================================================
# COMPANY BRANDING (for PDF quotations, invoices, receipts)
# ============================================================================
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=123 Main Street
COMPANY_CITY=City, Province Postal
COMPANY_PHONE=(555) 555-5555
COMPANY_EMAIL=info@example.com
COMPANY_LANDMARK=
COMPANY_WEBSITE=www.example.com

# ============================================================================
# INSTITUTIONAL INVOICING (payment instructions on invoice PDFs)
# ============================================================================
TELETIME_BANK_NAME=Your Bank
TELETIME_BANK_TRANSIT=00000
TELETIME_BANK_ACCOUNT=0000000
TELETIME_REMITTANCE_ADDRESS=Your Remittance Address
TELETIME_HST_NUMBER=000000000RT0001

# ============================================================================
# VENDOR PRODUCT SCRAPING (optional)
# ============================================================================
# Whirlpool Central portal: https://www.whirlpoolcentral.ca/
WHIRLPOOL_CENTRAL_USERNAME=your_username
WHIRLPOOL_CENTRAL_PASSWORD=your_password

# ============================================================================
# BARCODELOOKUP.COM (CE Product Import — Primary Source)
# ============================================================================
# Sign up at https://www.barcodelookup.com/api — primary source for CE product import
BARCODE_LOOKUP_API_KEY=your_barcodelookup_api_key

# ============================================================================
# ICECAT OPEN API (Consumer Electronics Integration — Fallback)
# ============================================================================
# Free-tier username from https://icecat.biz — fallback for CE product import
ICECAT_USERNAME=your_icecat_username

# ============================================================================
# PRICESAPI.IO (Competitor Pricing — free tier, 1,000 calls/month)
# ============================================================================
# Sign up at https://pricesapi.com — required for CE competitor pricing
PRICES_API_KEY=your_pricesapi_key

# ============================================================================
# REDIS (Velocity Tracking & BIN Caching for Fraud Detection)
# ============================================================================
# Connection URL — leave blank to use PostgreSQL fallback (slower but functional)
# Examples: redis://localhost:6379, rediss://user:pass@host:6380 (TLS)
REDIS_URL=

# ============================================================================
# MONERIS PAYMENT GATEWAY
# ============================================================================
# Webhook HMAC secret for verifying Moneris callback signatures.
# Configure matching secret in Moneris portal: https://www3.moneris.com/
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MONERIS_WEBHOOK_SECRET=CHANGE_ME_generate_with_crypto_randomBytes

# ============================================================================
# FRAUD DETECTION
# ============================================================================
# Salt for hashing card identifiers — MUST be a random 32+ character string.
# WARNING: Changing this will reset all velocity tracking history.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FRAUD_SALT=CHANGE-ME-generate-a-random-32-char-string

# ============================================================================
# MIRAKL MARKETPLACE (Best Buy Canada)
# ============================================================================
# Get API key from: https://marketplace.bestbuy.ca (Seller Portal > API Keys)
MIRAKL_API_URL=https://marketplace.bestbuy.ca
MIRAKL_API_KEY=your_mirakl_api_key
MIRAKL_SHOP_ID=your_shop_id
MARKETPLACE_AUTO_SYNC=true
# Comma-separated emails for daily marketplace summary (falls back to ADMIN_EMAIL)
MARKETPLACE_SUMMARY_EMAILS=
